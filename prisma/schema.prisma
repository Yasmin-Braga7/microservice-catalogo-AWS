generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Livro {
  id            Int          @id @default(autoincrement()) @map("livro_id")
  titulo        String       @map("livro_titulo") @db.VarChar(255)
  isbn          String       @unique(map: "livro_isbn") @map("livro_isbn") @db.VarChar(13)
  editora       String?      @map("livro_editora") @db.VarChar(100)
  anoPublicacao Int?         @map("livro_ano_publicacao")
  sinopse       String?      @map("livro_sinopse") @db.VarChar(100)
  numeroPaginas Int?         @map("livro_numero_paginas")
  idioma        String?      @map("livro_idioma") @db.VarChar(50)
  status        Int?         @map("livro_status")
  exemplares    Exemplar[]
  autores       LivroAutor[]

  @@map("livro")
}

model Autor {
  id             Int          @id @default(autoincrement()) @map("autor_id")
  nome           String       @map("autor_nome") @db.VarChar(200)
  dataNascimento DateTime?    @map("autor_data_nascimento") @db.Date
  nacionalidade  String?      @map("autor_nacionalidade") @db.VarChar(100)
  biografia      String?      @map("autor_biografia") @db.VarChar(100)
  status         Int?         @map("autor_status")
  livros         LivroAutor[]

  @@map("autor")
}

model Genero {
  id        Int     @id @default(autoincrement()) @map("genero_id")
  nome      String  @unique(map: "genero_nome") @map("genero_nome") @db.VarChar(100)
  descricao String? @map("genero_descricao") @db.VarChar(100)

  @@map("genero")
}

model LivroAutor {
  id      Int    @id @default(autoincrement()) @map("livro_autor_id")
  livroId Int?   @map("livro_id")
  autorId Int?   @map("autor_id")
  livro   Livro? @relation(fields: [livroId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk1")
  autor   Autor? @relation(fields: [autorId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk2")

  @@index([autorId], map: "autor_id")
  @@index([livroId], map: "livro_id")
  @@map("livro_autor")
}

model Exemplar {
  id              Int                         @id @default(autoincrement()) @map("exemplar_id")
  codigoBarras    String                      @unique(map: "exemplar_codigo_barras") @map("exemplar_codigo_barras") @db.VarChar(50)
  condicao        exemplar_exemplar_condicao? @map("exemplar_condicao")
  disponibilidade exemplar_exemplar_status?   @map("exemplar_status")
  dataAquisicao   DateTime?                   @map("exemplar_data_aquisicao") @db.Date
  livroId         Int                         @map("livro_id")
  livro           Livro                       @relation(fields: [livroId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_exemplar_livro1")

  @@index([livroId], map: "fk_exemplar_livro1_idx")
  @@map("exemplar")
}

enum exemplar_exemplar_condicao {
  Novo
  Bom
  Regular
  Desgastado
}

enum exemplar_exemplar_status {
  Disponivel
  Emprestado
  Manutencao
  Perdido
}
